# -----------------------------------------------------------------------------
# Nimbus Docs — Environment Variables
# Copy this file to `.env.local` for local development and fill in the values.
# Never commit real secrets. See docs/DEPLOYMENT.md for production setup.
# -----------------------------------------------------------------------------

# --- Database (Neon Postgres) ------------------------------------------------
# Pooled connection string (used by the app at runtime, via PgBouncer).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Direct (unpooled) connection string, required by Prisma Migrate.
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Authentication -----------------------------------------------------------
# Secrets used to sign short-lived access tokens and long-lived refresh tokens.
# Generate with: openssl rand -base64 48
AUTH_ACCESS_TOKEN_SECRET="replace-with-a-long-random-string"
AUTH_REFRESH_TOKEN_SECRET="replace-with-a-different-long-random-string"
AUTH_ACCESS_TOKEN_TTL="15m"
AUTH_REFRESH_TOKEN_TTL="30d"

# --- AI add-on features (optional) --------------------------------------------
# Nimbus Docs degrades gracefully to local heuristics when these are unset —
# no key is required to run or evaluate the app.
OPENAI_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# --- App -----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
